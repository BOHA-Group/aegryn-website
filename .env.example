# ── Site ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aegryn.com
NEXT_PUBLIC_SERVER_URL=https://aegryn.com

# ── Google Analytics ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Resend (emails) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM=contact@aegryn.com

# ── Payload CMS ──────────────────────────────────────────────────
# PAYLOAD_SECRET=GENERATE_32_CHARS_RANDOM
# DATABASE_URI=postgresql://user:password@localhost:5432/aegryn

# ── Cloudflare R2 (media) ────────────────────────────────────────
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=aegryn-media
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto

# ── Stripe ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ── CookieScript (optionnel) ─────────────────────────────────────
